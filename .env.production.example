# RegIntel AI — Production Environment Template (M10.3)
# Copy this file to `.env.production` and fill in real values.
# `.env.production` MUST be kept out of version control.

# ─── Runtime ───────────────────────────────────────────────────────
ENV=production
PROJECT_NAME=RegIntel AI
LOG_LEVEL=INFO
WORKERS=2
PORT=8000

# ─── Database ──────────────────────────────────────────────────────
# Production should use a managed Postgres with TLS. The default is
# asyncpg-compatible; swap to postgresql+asyncpg+ssl=require in real life.
DATABASE_URL=postgresql+asyncpg://regintel:CHANGE_ME@db:5432/regintel
DATABASE_URL_SYNC=postgresql+psycopg2://regintel:CHANGE_ME@db:5432/regintel
USE_PGVECTOR_FALLBACK=false

# ─── Storage ───────────────────────────────────────────────────────
STORAGE_ROOT=/var/lib/regintel/storage

# ─── Audit log ─────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PERSIST=true
AUDIT_LOG_PATH=/var/log/regintel/audit.log

# ─── Middleware ────────────────────────────────────────────────────
REQUEST_TRACING_ENABLED=true
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=300
API_KEY_AUTH_ENABLED=false
STARTUP_REQUIRED_ENV=DATABASE_URL,STORAGE_ROOT
STARTUP_RAISE_ON_ERROR=false

# ─── Embeddings (set to "cpu" in the production image) ────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_INSTRUCTION=represent this query for retrieving relevant documents: 

RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu
RERANKER_TOP_N=8

# ─── Cost / tokens (M9.9 + M10.5) ─────────────────────────────────
COST_PER_1K_INPUT_TOKENS=0.00015
COST_PER_1K_OUTPUT_TOKENS=0.00060
COST_PER_RETRIEVAL=0.00001
