# RegIntel AI — Production Environment Template (M10.3)
# Copy this file to `.env.production` and fill in real values.
# `.env.production` MUST be kept out of version control.

# ─── Runtime ───────────────────────────────────────────────────────
ENV=production
PROJECT_NAME=RegIntel AI
LOG_LEVEL=INFO
WORKERS=2
PORT=8000

# ─── Database ──────────────────────────────────────────────────────
# Production should use a managed Postgres with TLS. The default is
# asyncpg-compatible; swap to postgresql+asyncpg+ssl=require in real life.
DATABASE_URL=postgresql+asyncpg://regintel:CHANGE_ME@db:5432/regintel
DATABASE_URL_SYNC=postgresql+psycopg2://regintel:CHANGE_ME@db:5432/regintel
REGINTEL_DB_URL=${DATABASE_URL}
USE_PGVECTOR_FALLBACK=false

# ─── Storage ───────────────────────────────────────────────────────
STORAGE_ROOT=/var/lib/regintel/storage

# ─── Audit log ─────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PERSIST=true
AUDIT_LOG_PATH=/var/log/regintel/audit.log

# ─── Middleware ────────────────────────────────────────────────────
REQUEST_TRACING_ENABLED=true
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=300
API_KEY_AUTH_ENABLED=false
STARTUP_REQUIRED_ENV=DATABASE_URL,STORAGE_ROOT
STARTUP_RAISE_ON_ERROR=false

# ─── Embeddings (set to "cpu" in the production image) ────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_INSTRUCTION=represent this query for retrieving relevant documents: 

RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu
RERANKER_TOP_N=8

# ─── LLM / Answer Generation ──────────────────────────────────────
# Supported: openai | gemini | litellm
# "mock" is for development only — never use in production.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_API_KEY must be set via a secure mechanism (env, vault, k8s secret)
LLM_API_KEY=
LLM_API_BASE=
LLM_TIMEOUT_SEC=30.0
LLM_MAX_RETRIES=2
ANSWER_DEFAULT_TEMPERATURE=0.1
ANSWER_DEFAULT_MAX_TOKENS=1200
ANSWER_CONTEXT_TOKEN_BUDGET=6000
ANSWER_STREAMING_ENABLED=true

# ─── JWT Secret (minimum 32 characters) ──────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
REGINTEL_JWT_SECRET=

# ─── CORS (cross-origin API access) ───────────────────────────────
# Comma-separated origins permitted to call the API directly.
# Leave empty for same-origin only (via nginx reverse proxy).
REGINTEL_CORS_ORIGINS=

# ─── Object Storage (optional) ────────────────────────────────────
# Leave empty to use local storage only.
REGINTEL_OBJECT_STORE_BUCKET=
REGINTEL_OBJECT_STORE_ACCESS_KEY=
REGINTEL_OBJECT_STORE_SECRET_KEY=

# ─── OpenTelemetry (optional) ─────────────────────────────────────
# Leave empty to disable distributed tracing.
REGINTEL_OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Secrets / Vault (optional) ───────────────────────────────────
# Leave empty to resolve secrets from env vars only.
REGINTEL_VAULT_URL=
REGINTEL_VAULT_TOKEN=

# ─── Dev token endpoint (MUST be false in production) ─────────────
SECURITY_DEV_TOKEN_ENDPOINT=false

# ─── Demo mode ────────────────────────────────────────────────────
# Set to "false" to bypass all authentication for public demo access.
# Production MUST keep this as "true" (default).
AUTH_ENABLED=true
# Frontend must be built with VITE_AUTH_ENABLED=false for demo mode.

# ─── Account lockout ──────────────────────────────────────────────
# Failed login attempts before temporary lockout (0 = disabled).
AUTH_MAX_FAILED_ATTEMPTS=5
# Lockout duration in seconds after max failed attempts.
AUTH_LOCKOUT_DURATION_SECONDS=300

# ─── Cost / tokens (M9.9 + M10.5) ─────────────────────────────────
COST_PER_1K_INPUT_TOKENS=0.00015
COST_PER_1K_OUTPUT_TOKENS=0.00060
COST_PER_RETRIEVAL=0.00001
