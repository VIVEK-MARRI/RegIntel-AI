# Docker build context exclusions (M10.3)
# Keeps the production image small and the build deterministic.

# --- VCS / metadata ---
.git
.gitignore
.gitattributes
.github
.kilo

# --- Local virtualenv / caches ---
.venv
.venv-*
.venv-*/
.python-version
.ruff_cache
.mypy_cache
.pytest_cache
.cache
.coverage
.coverage.*
htmlcov
coverage.xml
nosetests.xml
.tox
.nox

# --- Editor / OS noise ---
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Local data and secrets ---
storage
.env
.env.*
!.env.production.example
*.log
logs
tmp
temp
__pycache__
*.pyc
*.pyo
*.pyd

# --- Frontend noise ---
frontend/node_modules
frontend/dist
frontend/.vite
frontend/coverage
frontend/.DS_Store

# --- Docker self-references (keep Dockerfile for dev builds) ---
docker-compose.production.yml
.dockerignore
# nginx.conf is intentionally NOT excluded: frontend/Dockerfile.production
# needs it in its build context (context: . in ci.yml). The backend
# Dockerfile never COPYs it, so it is harmless in that context too.
.env.production.example
